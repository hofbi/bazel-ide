########################
# Import bazelrc presets
import %workspace%/tools/preset.bazelrc

########################
# Project-specific flags
# This is also a place to override settings from the presets
common --repo_env=BAZEL_DO_NOT_DETECT_CPP_TOOLCHAIN=1
common --repo_env=BAZEL_NO_APPLE_CPP_TOOLCHAIN=1

# https://github.com/cerisier/toolchains_llvm_bootstrapped?tab=readme-ov-file#usage-with-rust
common --@llvm//config:experimental_stub_libgcc_s=True

# https://github.com/aspect-build/rules_py/blob/main/docs/uv.md
common --@python_deps//venv=bazel_ide

# rules_rs experimental toolchains require an explicit host platform with an
# ABI constraint for toolchain resolution to work.
# See: https://github.com/hermeticbuild/rules_rs?tab=readme-ov-file#platform-configuration
common:linux --host_platform=//platforms:local_gnu

########################
# User preferences
# Load any settings & overrides specific to the current user from `user.bazelrc`.
# This file should appear in `.gitignore` so that settings are not shared with team members.
# This should be last statement in this config so the user configuration overrides anything above.
try-import %workspace%/user.bazelrc
